#include <iostream>
#include <cstring> // Needed for strlen()
using namespace std;

int main() {
    int count = 0;
    char fruit[50];
    char vol[5] = {'a', 'e', 'i', 'o', 'u'};
    cout << "ENTER ANY WORD: ";
    cin >> fruit; 
    int length = strlen(fruit);
    for (int i = 0; i < length; i++) {
        for (int j = 0; j < 5; j++) { 
            if (fruit[i] == vol[j]) {
                count++;
            }
        }
    }
    cout << "TOTAL NUMBER OF VOWELS IN FRUIT NAME: " << count << endl;
    return 0;
};
